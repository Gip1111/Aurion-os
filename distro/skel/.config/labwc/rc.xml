<?xml version="1.0" encoding="UTF-8"?>
<!-- AurionOS labwc configuration — MVP -->
<labwc_config>

  <core>
    <decoration>server</decoration>
    <gap>6</gap>
  </core>

  <theme>
    <name></name>
    <cornerRadius>10</cornerRadius>
    <font place="ActiveWindow">
      <name>Inter</name>
      <size>13</size>
    </font>
    <font place="InactiveWindow">
      <name>Inter</name>
      <size>13</size>
    </font>
    <font place="MenuItem">
      <name>Inter</name>
      <size>13</size>
    </font>
  </theme>

  <keyboard>
    <!-- Launcher: Super+Space -->
    <keybind key="W-space">
      <action name="Execute">
        <command>dbus-send --session --type=method_call --dest=org.aurion.Shell /org/aurion/Shell org.aurion.Shell.ToggleLauncher</command>
      </action>
    </keybind>

    <!-- AI Sidebar: Super+A -->
    <keybind key="W-a">
      <action name="Execute">
        <command>dbus-send --session --type=method_call --dest=org.aurion.Shell /org/aurion/Shell org.aurion.Shell.ToggleAISidebar</command>
      </action>
    </keybind>

    <!-- Terminal: Super+Return -->
    <keybind key="W-Return">
      <action name="Execute">
        <command>foot</command>
      </action>
    </keybind>

    <!-- Close window: Alt+F4 -->
    <keybind key="A-F4">
      <action name="Close"/>
    </keybind>

    <!-- Alt+Tab: window cycling -->
    <keybind key="A-Tab">
      <action name="NextWindow"/>
    </keybind>

    <!-- Workspace switching: Super+Left/Right -->
    <keybind key="W-Left">
      <action name="GoToDesktop"><to>left</to><wrap>yes</wrap></action>
    </keybind>
    <keybind key="W-Right">
      <action name="GoToDesktop"><to>right</to><wrap>yes</wrap></action>
    </keybind>

    <!-- Window snap: Super+Shift+Left/Right -->
    <keybind key="W-S-Left">
      <action name="SnapToEdge"><direction>left</direction></action>
    </keybind>
    <keybind key="W-S-Right">
      <action name="SnapToEdge"><direction>right</direction></action>
    </keybind>
    <keybind key="W-Up">
      <action name="Maximize"/>
    </keybind>
    <keybind key="W-Down">
      <action name="UnMaximize"/>
    </keybind>

    <!-- Fullscreen: Super+F -->
    <keybind key="W-f">
      <action name="ToggleFullscreen"/>
    </keybind>
  </keyboard>

  <mouse>
    <context name="TitleBar">
      <mousebind button="Left" action="Press">
        <action name="Focus"/>
        <action name="Raise"/>
      </mousebind>
      <mousebind button="Left" action="Drag">
        <action name="Move"/>
      </mousebind>
      <mousebind button="Right" action="Press">
        <action name="Focus"/>
        <action name="Raise"/>
        <action name="ShowMenu"><menu>client-menu</menu></action>
      </mousebind>
    </context>
    <context name="Frame">
      <mousebind button="A-Left" action="Drag">
        <action name="Move"/>
      </mousebind>
      <mousebind button="A-Right" action="Drag">
        <action name="Resize"/>
      </mousebind>
    </context>
  </mouse>

  <desktops number="4"/>

</labwc_config>
