#!/bin/bash
# AurionOS Session Startup Script
# Called by greetd or manually: aurion-session
# Starts labwc compositor, which then autostarts the shell and services.
#
# NB: do NOT use `set -e` here — if any single setup step fails we still want
# to launch the compositor. A failing session here = greetd restart loop =
# text login from the user's perspective.

LOG="${XDG_RUNTIME_DIR:-/tmp}/aurion-session.log"
exec >>"$LOG" 2>&1
echo "=== aurion-session starting at $(date) as $(id) ==="

# --- Environment ---
export XDG_CURRENT_DESKTOP=AurionOS
export XDG_SESSION_TYPE=wayland
export XDG_SESSION_DESKTOP=aurion
export QT_QPA_PLATFORM=wayland
export QT_WAYLAND_DISABLE_WINDOWDECORATION=1
export MOZ_ENABLE_WAYLAND=1
export GDK_BACKEND=wayland
export QT_STYLE_OVERRIDE=Fusion

# XDG_RUNTIME_DIR is required by Wayland compositors
if [ -z "${XDG_RUNTIME_DIR:-}" ]; then
    export XDG_RUNTIME_DIR="/run/user/$(id -u)"
    mkdir -p "$XDG_RUNTIME_DIR"
    chmod 700 "$XDG_RUNTIME_DIR"
fi

# --- Start user services (best-effort) ---
systemctl --user start aurion-ai.service 2>/dev/null || true

# --- Launch compositor under a fresh dbus session ---
# dbus-run-session replaces the old `eval dbus-launch` pattern and guarantees
# the session bus is torn down when labwc exits.
if command -v labwc >/dev/null 2>&1; then
    if command -v dbus-run-session >/dev/null 2>&1; then
        echo "Launching: dbus-run-session -- labwc"
        exec dbus-run-session -- labwc
    else
        echo "dbus-run-session not found, launching labwc directly"
        exec labwc
    fi
fi

# --- Fallback: if labwc is missing, drop to a tty shell so the user can debug
# instead of an infinite greetd restart loop that looks like "just a text login".
echo "FATAL: labwc not installed. Dropping to shell on tty so the user can debug."
echo "Check $LOG for details."
exec /bin/bash -l
