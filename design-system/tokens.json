{
  "name": "AurionOS Design Tokens",
  "version": "0.1.0",
  "colors": {
    "dark": {
      "bg": {
        "deep": "#0A0E1A",
        "base": "#111827",
        "elevated": "#1E293B",
        "overlay": "rgba(17, 24, 39, 0.85)"
      },
      "fg": {
        "primary": "#F1F5F9",
        "secondary": "#94A3B8",
        "muted": "#64748B",
        "inverse": "#0F172A"
      },
      "accent": {
        "primary": "#6366F1",
        "hover": "#818CF8",
        "glow": "rgba(99, 102, 241, 0.25)",
        "warm": "#F59E0B",
        "success": "#10B981",
        "danger": "#EF4444"
      },
      "glass": {
        "background": "rgba(17, 24, 39, 0.65)",
        "border": "rgba(148, 163, 184, 0.12)",
        "blur": "24px"
      },
      "status": {
        "ok": "#10B981",
        "warn": "#F59E0B",
        "error": "#EF4444",
        "unknown": "#64748B"
      }
    },
    "light": {
      "bg": {
        "base": "#F8FAFC",
        "elevated": "#FFFFFF"
      },
      "fg": {
        "primary": "#0F172A",
        "secondary": "#475569"
      },
      "status": {
        "ok": "#059669",
        "warn": "#D97706",
        "error": "#DC2626",
        "unknown": "#94A3B8"
      }
    }
  },
  "typography": {
    "fontFamilies": {
      "primary": "Inter",
      "mono": "JetBrains Mono",
      "display": "Outfit"
    },
    "scale": {
      "display-xl": { "size": 48, "weight": 700, "lineHeight": 1.1 },
      "display-lg": { "size": 32, "weight": 600, "lineHeight": 1.2 },
      "heading-lg": { "size": 24, "weight": 600, "lineHeight": 1.3 },
      "heading-md": { "size": 18, "weight": 600, "lineHeight": 1.3 },
      "heading-sm": { "size": 15, "weight": 600, "lineHeight": 1.4 },
      "body-lg":    { "size": 15, "weight": 400, "lineHeight": 1.5 },
      "body-md":    { "size": 13, "weight": 400, "lineHeight": 1.5 },
      "body-sm":    { "size": 11, "weight": 400, "lineHeight": 1.4 },
      "label-md":   { "size": 13, "weight": 500, "lineHeight": 1.2 },
      "label-sm":   { "size": 11, "weight": 500, "lineHeight": 1.2 },
      "mono-md":    { "size": 13, "weight": 400, "lineHeight": 1.5 },
      "mono-sm":    { "size": 11, "weight": 400, "lineHeight": 1.4 }
    }
  },
  "spacing": {
    "xs": 4,
    "sm": 8,
    "md": 12,
    "lg": 16,
    "xl": 24,
    "2xl": 32,
    "3xl": 48
  },
  "radius": {
    "sm": 6,
    "md": 10,
    "lg": 16,
    "xl": 24,
    "full": 9999
  },
  "animation": {
    "duration": {
      "fast": "120ms",
      "normal": "200ms",
      "slow": "350ms",
      "page": "500ms"
    },
    "easing": {
      "default": "cubic-bezier(0.4, 0, 0.2, 1)",
      "in": "cubic-bezier(0.4, 0, 1, 1)",
      "out": "cubic-bezier(0, 0, 0.2, 1)",
      "spring": "cubic-bezier(0.34, 1.56, 0.64, 1)"
    }
  }
}
